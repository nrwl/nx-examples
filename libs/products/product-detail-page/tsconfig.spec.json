{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/spec",
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "es2016",
    "isolatedModules": true,
    "types": ["jest", "node"],
    "tsBuildInfoFile": "out-tsc/spec/tsconfig.spec.tsbuildinfo"
  },
  "include": ["**/*.spec.ts", "**/*.test.ts", "**/*.d.ts", "jest.config.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ],
  "exclude": ["out-tsc"]
}
